# GramStep public example environment file
# Do not commit real values. Use placeholders only.

# Web app
# Used by Next.js admin UI. For local dev, this can point to your local or deployed Worker.
NEXT_PUBLIC_API_URL=https://your-worker.your-subdomain.workers.dev

# Worker runtime configuration
# META_API_VERSION is a plain var. The others should be stored as Wrangler secrets.
META_API_VERSION=v25.0
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
WEBHOOK_VERIFY_TOKEN=generate_a_random_verify_token
ENCRYPTION_KEY=generate_a_random_32byte_key
JWT_SECRET=generate_a_random_jwt_secret
REFRESH_SECRET=generate_a_random_refresh_secret
DASHBOARD_URL=https://your-admin.your-subdomain.workers.dev
SLO_NOTIFY_WEBHOOK_URL=

# Cloudflare resource names and IDs
# Keep real IDs out of git. These are reference placeholders only.
D1_DATABASE_NAME=gramstep
D1_DATABASE_ID=your_d1_database_id
KV_NAMESPACE_ID=your_kv_namespace_id
SEND_QUEUE_NAME=gramstep-send
DLQ_NAME=gramstep-dlq
R2_BUCKET_NAME=gramstep-storage
WORKER_NAME=gramstep-worker
